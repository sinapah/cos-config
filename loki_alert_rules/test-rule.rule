groups:
  - name: example-alerts
    interval: 1m
    rules:
      - alert: HighErrorRate
        expr: |
          sum(rate({job="app"} |= "error" [5m])) > 0.5
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "High error rate detected"
          description: "Error rate is above threshold for the last 5 minutes."

      - alert: NoLogsReceived
        expr: |
          sum(rate({job="app"}[5m])) == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "No logs received"
          description: "No logs have been received from job=app in the last 5 minutes."

      - alert: SpikeInWarnings
        expr: |
          sum(rate({job="app"} |= "warn" [1m])) > 5
        for: 1m
        labels:
          severity: info
        annotations:
          summary: "Spike in warnings"
          description: "Warning logs spiked above normal levels."